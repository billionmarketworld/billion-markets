{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.3",
            "config": {
                "maxExecutionTime": 30,
                "phpVersion": "8.2",
                "extensions": ["pdo_pgsql", "pgsql", "bcmath", "mbstring", "openssl"]
            }
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "BOOTSTRAP_CACHE_PATH": "/tmp"
    }
}